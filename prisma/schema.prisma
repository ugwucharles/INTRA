generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now())

  users             User[]
  customers         Customer[]
  conversations     Conversation[]
  auditLogs         AuditLog[]
  departments       Department[]
  routingSettings   RoutingSettings?
  autoReplies       AutoReply[]
  customerNotes     CustomerNote[]
  tags              Tag[]
  conversationNotes ConversationNote[]
  savedReplies      SavedReply[]
}

model Department {
  id        String   @id @default(cuid())
  orgId     String   @db.Uuid
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org           Organization @relation(fields: [orgId], references: [id])
  users         User[]
  conversations Conversation[]
  autoReplies   AutoReply[]
  savedReplies  SavedReply[]
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  orgId     String    @db.Uuid
  name      String
  email     String
  password  String
  role      UserRole  @default(AGENT)
  isActive  Boolean   @default(true)
  isOnline  Boolean   @default(true)
  createdAt DateTime  @default(now())

  org                   Organization   @relation(fields: [orgId], references: [id])
  assignedConversations Conversation[]
  departments           Department[]
  customerNotes         CustomerNote[]
  conversationNotes     ConversationNote[]

  @@unique([orgId, email])
}

enum UserRole {
  ADMIN
  AGENT
}

model Customer {
  id        String   @id @default(cuid())
  orgId     String   @db.Uuid
  name      String?
  email     String?
  phone     String?
  // Optional: external identifier from third-party channels (e.g. Facebook PSID, Instagram user id)
  externalId String?
  // Optional: source channel for this customer (e.g. FACEBOOK_MESSENGER, INSTAGRAM)
  source     Channel?
  // Optional: page/account id for channels like Facebook Pages or Instagram accounts
  pageId     String?
  // Whether this customer has been explicitly saved as a contact in the CRM
  isSaved   Boolean  @default(false)
  createdAt DateTime @default(now())

  org           Organization  @relation(fields: [orgId], references: [id])
  conversations Conversation[]
  notes          CustomerNote[]
  tags           CustomerTag[]

  @@unique([orgId, source, externalId])
}

model Conversation {
  id          String              @id @default(cuid())
  orgId       String              @db.Uuid
  customerId  String
  assignedTo  String?             @db.Uuid
  status      ConversationStatus  @default(OPEN)
  isStarred   Boolean             @default(false)
  unreadCount Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // Routing metadata
  departmentId        String?
  routingQuestionSent Boolean  @default(false)
  routingMetadata     Json?

  org        Organization @relation(fields: [orgId], references: [id])
  customer   Customer     @relation(fields: [customerId], references: [id])
  assignee   User?        @relation(fields: [assignedTo], references: [id])
  department Department?  @relation(fields: [departmentId], references: [id])
  messages   Message[]
  tags       ConversationTag[]
  notes      ConversationNote[]
}

enum ConversationStatus {
  OPEN
  CLOSED
  PENDING
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  senderType     SenderType
  senderId       String?
  content        String
  // Optional external message id from providers (e.g. Meta mid)
  externalId     String?
  status         MessageStatus @default(SENT)
  retryCount     Int           @default(0)
  createdAt      DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@unique([conversationId, externalId])
}

model AuditLog {
  id         String      @id @default(cuid())
  orgId      String      @db.Uuid
  userId     String      @db.Uuid
  action     AuditAction
  targetId   String
  targetType String
  createdAt  DateTime    @default(now())

  org Organization @relation(fields: [orgId], references: [id])
}

model CustomerNote {
  id         String   @id @default(cuid())
  orgId      String   @db.Uuid
  customerId String
  userId     String   @db.Uuid
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org      Organization @relation(fields: [orgId], references: [id])
  customer Customer     @relation(fields: [customerId], references: [id])
  user     User         @relation(fields: [userId], references: [id])

  @@unique([customerId, userId])
}

model RoutingSettings {
  id                 String            @id @default(cuid())
  orgId              String            @unique @db.Uuid
  autoRoutingEnabled Boolean           @default(true)
  routeTo            RouteTo           @default(LIVE_AGENTS_ONLY)
  fallbackBehavior   FallbackBehavior  @default(ASSIGN_ADMIN)
  afterHoursConfig   Json?
  metadata           Json?

  org Organization @relation(fields: [orgId], references: [id])
}

model AutoReply {
  id           String           @id @default(cuid())
  orgId        String           @db.Uuid
  trigger      AutoReplyTrigger
  departmentId String?
  message      String
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  metadata     Json?

  org        Organization @relation(fields: [orgId], references: [id])
  department Department?  @relation(fields: [departmentId], references: [id])
}

model Tag {
  id        String   @id @default(cuid())
  orgId     String   @db.Uuid
  name      String
  type      TagType
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org               Organization     @relation(fields: [orgId], references: [id])
  conversationTags  ConversationTag[]
  customerTags      CustomerTag[]
}

enum TagType {
  CONVERSATION
  CUSTOMER
}

model ConversationTag {
  conversationId String
  tagId          String

  conversation Conversation @relation(fields: [conversationId], references: [id])
  tag          Tag          @relation(fields: [tagId], references: [id])

  @@id([conversationId, tagId])
}

model CustomerTag {
  customerId String
  tagId      String

  customer Customer @relation(fields: [customerId], references: [id])
  tag      Tag      @relation(fields: [tagId], references: [id])

  @@id([customerId, tagId])
}

model ConversationNote {
  id             String   @id @default(cuid())
  orgId          String   @db.Uuid
  conversationId String
  authorId       String   @db.Uuid
  content        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org          Organization @relation(fields: [orgId], references: [id])
  conversation Conversation  @relation(fields: [conversationId], references: [id])
  author       User          @relation(fields: [authorId], references: [id])
}

model SavedReply {
  id           String   @id @default(cuid())
  orgId        String   @db.Uuid
  departmentId String?
  name         String
  shortcut     String?
  body         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org        Organization @relation(fields: [orgId], references: [id])
  department Department?  @relation(fields: [departmentId], references: [id])

  @@index([orgId, departmentId])
}

enum AuditAction {
  MESSAGE_SENT
  CONVERSATION_ASSIGNED
  CONVERSATION_CLOSED
  CONVERSATION_STATUS_CHANGED
  CONVERSATION_TAG_ADDED
  CONVERSATION_TAG_REMOVED
  CUSTOMER_TAG_ADDED
  CUSTOMER_TAG_REMOVED
  CONVERSATION_NOTE_CREATED
  CONVERSATION_NOTE_UPDATED
  CONVERSATION_NOTE_DELETED
  SAVED_REPLY_CREATED
  SAVED_REPLY_UPDATED
  SAVED_REPLY_DELETED
  ROUTING_SETTINGS_UPDATED
  BUSINESS_HOURS_UPDATED
}

enum SenderType {
  CUSTOMER
  STAFF
}

enum Channel {
  FACEBOOK_MESSENGER
  INSTAGRAM
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}

enum RouteTo {
  LIVE_AGENTS_ONLY
  OFFLINE_ALLOWED
}

enum FallbackBehavior {
  NONE
  ASSIGN_ANY_AGENT
  ASSIGN_ADMIN
}

enum AutoReplyTrigger {
  FIRST_MESSAGE
  DEPARTMENT_SELECTION
  NO_AGENT_AVAILABLE
  AFTER_HOURS
}
