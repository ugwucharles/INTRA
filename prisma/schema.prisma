generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                String             @id @default(uuid())
  name              String
  createdAt         DateTime           @default(now())
  address           String?
  country           String?
  isOnboarded       Boolean            @default(false)
  phone             String?
  auditLogs         AuditLog[]
  autoReplies       AutoReply[]
  conversations     Conversation[]
  conversationNotes ConversationNote[]
  conversationTags  ConversationTag[]
  customers         Customer[]
  customerNotes     CustomerNote[]
  customerTags      CustomerTag[]
  departments       Department[]
  messages          Message[]
  routingSettings   RoutingSettings?
  savedReplies      SavedReply[]
  socialAccounts    SocialAccount[]
  tags              Tag[]
  users             User[]
}

model SocialAccount {
  id            String       @id @default(cuid())
  orgId         String
  channel       Channel
  displayName   String?
  pageId        String?
  accessToken   String
  appSecret     String?
  phoneNumberId String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  org           Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, channel])
  @@index([pageId])
}

model Department {
  id            String         @id @default(cuid())
  orgId         String
  name          String
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  autoReplies   AutoReply[]
  conversations Conversation[]
  org           Organization   @relation(fields: [orgId], references: [id])
  savedReplies  SavedReply[]
  users         User[]         @relation("DepartmentToUser")
}

model User {
  id                    String             @id @default(uuid())
  orgId                 String
  name                  String
  email                 String
  password              String
  role                  UserRole           @default(AGENT)
  isActive              Boolean            @default(true)
  createdAt             DateTime           @default(now())
  isOnline              Boolean            @default(true)
  level                 String?
  profilePicture        String?
  title                 String?
  ratingCount           Int                @default(0)
  ratingTotal           Float              @default(0)
  assignedConversations Conversation[]
  conversationNotes     ConversationNote[]
  customerNotes         CustomerNote[]
  org                   Organization       @relation(fields: [orgId], references: [id])
  departments           Department[]       @relation("DepartmentToUser")

  @@unique([orgId, email])
}

model Customer {
  id            String         @id @default(cuid())
  orgId         String
  name          String?
  email         String?
  phone         String?
  createdAt     DateTime       @default(now())
  externalId    String?
  source        Channel?
  pageId        String?
  isSaved       Boolean        @default(false)
  conversations Conversation[]
  org           Organization   @relation(fields: [orgId], references: [id])
  notes         CustomerNote[]
  tags          CustomerTag[]

  @@unique([orgId, source, externalId])
}

model Conversation {
  id                  String             @id @default(cuid())
  orgId               String
  customerId          String
  assignedTo          String?
  status              ConversationStatus @default(OPEN)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  unreadCount         Int                @default(0)
  departmentId        String?
  routingQuestionSent Boolean            @default(false)
  routingMetadata     Json?
  isStarred           Boolean            @default(false)
  awaitingRating      Boolean            @default(false)
  customerRating      Int?
  resolvedBy          String?
  firstResponseTime   Int?
  assignee            User?              @relation(fields: [assignedTo], references: [id])
  customer            Customer           @relation(fields: [customerId], references: [id])
  department          Department?        @relation(fields: [departmentId], references: [id])
  org                 Organization       @relation(fields: [orgId], references: [id])
  notes               ConversationNote[]
  tags                ConversationTag[]
  messages            Message[]
}

model Message {
  id             String        @id @default(cuid())
  orgId          String
  conversationId String
  senderType     SenderType
  senderId       String?
  content        String
  createdAt      DateTime      @default(now())
  externalId     String?
  retryCount     Int           @default(0)
  status         MessageStatus @default(SENT)
  conversation   Conversation  @relation(fields: [conversationId], references: [id])
  org            Organization  @relation(fields: [orgId], references: [id])

  @@unique([conversationId, externalId])
  @@index([orgId])
  @@index([conversationId, orgId])
}

model AuditLog {
  id         String       @id @default(cuid())
  orgId      String
  userId     String
  action     AuditAction
  targetId   String
  targetType String
  createdAt  DateTime     @default(now())
  org        Organization @relation(fields: [orgId], references: [id])
}

model CustomerNote {
  id         String       @id @default(cuid())
  orgId      String
  customerId String
  userId     String
  content    String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  customer   Customer     @relation(fields: [customerId], references: [id])
  org        Organization @relation(fields: [orgId], references: [id])
  user       User         @relation(fields: [userId], references: [id])

  @@unique([customerId, userId])
}

model RoutingSettings {
  id                 String           @id @default(cuid())
  orgId              String           @unique
  autoRoutingEnabled Boolean          @default(true)
  routeTo            RouteTo          @default(LIVE_AGENTS_ONLY)
  fallbackBehavior   FallbackBehavior @default(ASSIGN_ADMIN)
  afterHoursConfig   Json?
  metadata           Json?
  org                Organization     @relation(fields: [orgId], references: [id])
}

model AutoReply {
  id           String           @id @default(cuid())
  orgId        String
  trigger      AutoReplyTrigger
  departmentId String?
  message      String
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  metadata     Json?
  department   Department?      @relation(fields: [departmentId], references: [id])
  org          Organization     @relation(fields: [orgId], references: [id])
}

model Tag {
  id               String            @id @default(cuid())
  orgId            String
  name             String
  type             TagType
  color            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  conversationTags ConversationTag[]
  customerTags     CustomerTag[]
  org              Organization      @relation(fields: [orgId], references: [id])
}

model ConversationTag {
  orgId          String
  conversationId String
  tagId          String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  tag            Tag          @relation(fields: [tagId], references: [id])
  org            Organization @relation(fields: [orgId], references: [id])

  @@id([conversationId, tagId])
  @@index([orgId])
}

model CustomerTag {
  orgId      String
  customerId String
  tagId      String
  customer   Customer @relation(fields: [customerId], references: [id])
  tag        Tag      @relation(fields: [tagId], references: [id])
  org        Organization @relation(fields: [orgId], references: [id])

  @@id([customerId, tagId])
  @@index([orgId])
}

model ConversationNote {
  id             String       @id @default(cuid())
  orgId          String
  conversationId String
  authorId       String
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  author         User         @relation(fields: [authorId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  org            Organization @relation(fields: [orgId], references: [id])
}

model SavedReply {
  id           String       @id @default(cuid())
  orgId        String
  departmentId String?
  name         String
  shortcut     String?
  body         String
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  department   Department?  @relation(fields: [departmentId], references: [id])
  org          Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, departmentId])
}

enum UserRole {
  ADMIN
  AGENT
}

enum ConversationStatus {
  OPEN
  CLOSED
  PENDING
  RESOLVED
}

enum TagType {
  CONVERSATION
  CUSTOMER
}

enum AuditAction {
  MESSAGE_SENT
  CONVERSATION_ASSIGNED
  CONVERSATION_CLOSED
  CONVERSATION_STATUS_CHANGED
  CONVERSATION_TAG_ADDED
  CONVERSATION_TAG_REMOVED
  CUSTOMER_TAG_ADDED
  CUSTOMER_TAG_REMOVED
  CONVERSATION_NOTE_CREATED
  CONVERSATION_NOTE_UPDATED
  CONVERSATION_NOTE_DELETED
  SAVED_REPLY_CREATED
  SAVED_REPLY_UPDATED
  SAVED_REPLY_DELETED
  ROUTING_SETTINGS_UPDATED
  BUSINESS_HOURS_UPDATED
  CONVERSATION_RESOLVED
}

enum SenderType {
  CUSTOMER
  STAFF
}

enum Channel {
  FACEBOOK_MESSENGER
  INSTAGRAM
  WHATSAPP
  EMAIL
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}

enum RouteTo {
  LIVE_AGENTS_ONLY
  OFFLINE_ALLOWED
}

enum FallbackBehavior {
  NONE
  ASSIGN_ANY_AGENT
  ASSIGN_ADMIN
}

enum AutoReplyTrigger {
  FIRST_MESSAGE
  DEPARTMENT_SELECTION
  NO_AGENT_AVAILABLE
  AFTER_HOURS
}
