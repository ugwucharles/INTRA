## Copy to `.env` and fill in real values.
##
## Required for backend startup (see `src/main.ts`).
##
## Postgres connection string example:
## DATABASE_URL="postgresql://postgres:password@localhost:5432/intra?schema=public"
DATABASE_URL=""

## Used to sign auth tokens (set to a long random string)
JWT_SECRET=""

## Meta (Facebook/Instagram) webhook + API credentials
META_VERIFY_TOKEN=""
META_DEFAULT_ORG_ID=""
META_APP_SECRET=""
META_APP_ID=""
META_OAUTH_REDIRECT_URI=""
META_PAGE_ACCESS_TOKEN=""
FRONTEND_URL="http://localhost:3001"

## Google OAuth (Sign in / Sign up)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

## Optional
PORT=3000
