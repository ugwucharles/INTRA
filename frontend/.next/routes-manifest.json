    {
      "page": "/dashboard/staff",
      "regex": "^/dashboard/staff(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/staff(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
