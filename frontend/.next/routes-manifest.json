    {
      "page": "/dashboard/routing",
      "regex": "^/dashboard/routing(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/routing(?:/)?$"
    },
    {
      "page": "/dashboard/routing/auto-replies",
      "regex": "^/dashboard/routing/auto\\-replies(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/routing/auto\\-replies(?:/)?$"
    },
    {
      "page": "/dashboard/routing/business-availability",
      "regex": "^/dashboard/routing/business\\-availability(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/routing/business\\-availability(?:/)?$"
